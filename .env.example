# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key — used as a fallback when the user has not entered a per-browser
# key via Settings > API Configuration. localStorage takes priority. Useful for pilot
# users who shouldn't have to paste a key into their browser themselves.
VITE_ANTHROPIC_API_KEY=

# Google Gemini API key — used to generate images via Imagen 3 directly from Aanya's
# creative prompts. Get a key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# === Meta Marketing API ===
# System User token from AWAAS Business Manager (ads_read scope)
# Generate at: Business Manager → Settings → System Users → Generate Token
# META_SYSTEM_USER_TOKEN and META_AD_ACCOUNT_ID are set as Supabase Edge Function
# secrets (supabase secrets set ...), NOT exposed to the browser.

# === Canva Connect API ===
# Register app at: canva.dev → Create app
VITE_CANVA_CLIENT_ID=your_canva_client_id_here
# CANVA_CLIENT_SECRET is a server-side secret — set via: supabase secrets set CANVA_CLIENT_SECRET=...

# === Adobe Express Embed SDK ===
# Register at: developer.adobe.com → Create project → Express Embed SDK
VITE_ADOBE_EXPRESS_CLIENT_ID=your_adobe_client_id_here

# === App URL (used in Canva OAuth redirect) ===
# Set this to your production domain or local dev URL
# Also set as Supabase Edge Function secret: supabase secrets set APP_URL=https://yourapp.com
VITE_APP_URL=http://localhost:5173

# === Feature Flags ===
# LeadGen V2 (Aarav agent split-pane workspace) — set to 'true' to enable. Default off.
VITE_LEADGEN_V2_ENABLED=false

# === Langfuse (LLM observability) ===
# Server-side only — never VITE_-prefixed. Get keys at Langfuse → Settings → API Keys.
# In production set as Supabase Edge Function secrets, NOT in the client env:
#   supabase secrets set LANGFUSE_SECRET_KEY=sk-lf-... LANGFUSE_PUBLIC_KEY=pk-lf-... LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
